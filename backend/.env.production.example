FLASK_ENV=production
PORT=5000
MYSQL_ENABLED=1
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=smart_opd
MYSQL_USER=smartopd
MYSQL_PASSWORD_FILE=/run/secrets/mysql_password
APP_SECRET_KEY_FILE=/run/secrets/app_secret_key
APP_ALLOWED_ORIGINS=https://hospital.example.in
ACCESS_TOKEN_TTL_SECONDS=28800
RESET_TOKEN_TTL_MINUTES=30
OTP_MODE=live
OTP_PROVIDER=msg91
OTP_CHANNEL=sms
OTP_EXPIRY_MINUTES=5
OTP_MESSAGE_TEMPLATE=Smart OPD verification code: {code}. It expires in {minutes} minutes.
NOTIFICATION_MODE=live
SMS_PROVIDER=msg91
WHATSAPP_PROVIDER=gupshup
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN_FILE=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
MSG91_AUTH_KEY_FILE=/run/secrets/msg91_auth_key
MSG91_SMS_URL=https://control.msg91.com/api/v5/flow/
MSG91_SMS_FLOW_ID=
MSG91_SMS_FLOW_MESSAGE_VAR=message
MSG91_SMS_SENDER=
MSG91_SMS_ROUTE=
MSG91_SMS_TEMPLATE_ID=
GUPSHUP_API_KEY_FILE=/run/secrets/gupshup_api_key
GUPSHUP_APP_NAME=SmartOPD
GUPSHUP_WHATSAPP_URL=https://api.gupshup.io/wa/api/v1/msg
GUPSHUP_WHATSAPP_SOURCE=
GUPSHUP_SMS_URL=https://enterprise.smsgupshup.com/GatewayAPI/rest
GUPSHUP_SMS_USER_ID=
GUPSHUP_SMS_PASSWORD_FILE=/run/secrets/gupshup_sms_password
GUPSHUP_SMS_SENDER=
GUPSHUP_SMS_ENTITY_ID=
GUPSHUP_SMS_TEMPLATE_ID=
NOTIFICATION_WEBHOOK_URL=
SMS_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=
PROVIDER_WEBHOOK_TOKEN_FILE=/run/secrets/provider_webhook_token
MSG91_WEBHOOK_TOKEN=
GUPSHUP_WEBHOOK_TOKEN=
TWILIO_WEBHOOK_TOKEN=
